# Github Package Registry for io.github.bluetape4k
gpr.user=YOUR_GITHUB_USERNAME
gpr.key=YOUR_GITHUB_TOKEN

gpr.publish.key=YOUR_GITHUB_PUBLISH_TOKEN

bluetape4k.gpr.user=YOUR_GITHUB_USERNAME
bluetape4k.gpr.key=YOUR_GITHUB_TOKEN
bluetape4k.gpr.publish.key=YOUR_GITHUB_PUBLISH_TOKEN

# Kotlin Daemon JVM Options
kotlin.daemon.jvm.options=-Xms2G -Xmx4G -XX:+UseZGC -XX:+ZGenerational -Dfile.encoding=UTF-8 -XX:-MaxFDLimit -XX:+UnlockExperimentalVMOptions

# Maven Central Publishing (값은 직접 입력 — 절대 커밋 금지)
# central.user=
# central.password=

# GPG Signing (값은 직접 입력 — 절대 커밋 금지)
# signingUseGpgCmd=true
# signinKeyId=
# signingKey=
# signingPassword=
